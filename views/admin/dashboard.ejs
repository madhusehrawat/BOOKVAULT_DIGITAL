<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
  :root {
    --ink: #0a0a0f;
    --ink2: #1c1c28;
    --muted: #6b7280;
    --border: #e5e7eb;
    --surface: #f9fafb;
    --white: #ffffff;
    --blue: #2563eb;
    --blue-light: #eff6ff;
    --amber: #f59e0b;
    --amber-light: #fffbeb;
    --green: #10b981;
    --green-light: #ecfdf5;
    --red: #ef4444;
    --red-light: #fef2f2;
    --purple: #8b5cf6;
    --purple-light: #f5f3ff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Space Grotesk', sans-serif; background: var(--surface); color: var(--ink); }
  .syne { font-family: 'Syne', sans-serif; }

  .tab-btn { transition: all .2s; }
  .tab-btn.active { background: var(--ink); color: #fff; }
  .tab-pane { display: none; }
  .tab-pane.active { display: block; }

  .data-row { transition: background .15s; }
  .data-row:hover { background: var(--surface); }
  .stat-card { transition: transform .2s, box-shadow .2s; }
  .stat-card:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,.08); }

  .modal-wrap { backdrop-filter: blur(6px); }
  .toggle-track { width:44px; height:24px; border-radius:99px; transition: background .2s; cursor:pointer; display:inline-flex; align-items:center; padding:2px; }
  .toggle-thumb { width:20px; height:20px; border-radius:50%; background:#fff; box-shadow:0 1px 4px rgba(0,0,0,.25); transition: transform .2s; }
  .toggle-track.on { background: var(--amber); }
  .toggle-track.off { background: #d1d5db; }
  .toggle-track.on .toggle-thumb { transform: translateX(20px); }
  .search-input:focus { outline: none; box-shadow: 0 0 0 3px rgba(37,99,235,.15); }
  .badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:99px; font-size:10px; font-weight:700; letter-spacing:.05em; text-transform:uppercase; }
  .pill-btn { border-radius:99px; font-weight:700; font-size:12px; padding:6px 16px; transition: all .15s; cursor:pointer; border:none; }
  .pill-btn:hover { filter: brightness(.92); }
  .pill-btn:active { transform: scale(.96); }

  .inline-edit { border:none; background:transparent; font-family:inherit; font-size:inherit; font-weight:inherit; color:inherit; width:100%; }
  .inline-edit:focus { outline:2px solid var(--blue); border-radius:6px; background:#fff; padding:2px 6px; }

  ::-webkit-scrollbar { width:6px; height:6px; }
  ::-webkit-scrollbar-thumb { background:#d1d5db; border-radius:99px; }

  @keyframes slideUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
  .slide-up { animation: slideUp .35s ease forwards; }
  @keyframes fadeIn { from{opacity:0}to{opacity:1} }
  .fade-in { animation: fadeIn .3s ease forwards; }
</style>

<div class="min-h-screen pb-20">
  <div style="background:var(--ink2)" class="px-8 py-6 mb-8">
    <div class="max-w-7xl mx-auto flex flex-wrap justify-between items-center gap-4">
      <div>
        <h1 class="syne text-white text-3xl font-extrabold tracking-tight">Admin Control Panel</h1>
        <p style="color:#9ca3af" class="text-sm mt-1">BookVault · System Management</p>
      </div>
      <div class="flex gap-3">
        <button onclick="openAddBookModal()" 
                style="background:var(--blue)" 
                class="pill-btn text-white px-5 py-2.5 text-sm flex items-center gap-2 shadow-lg">
          <i class="fas fa-plus"></i> Add Book
        </button>
       
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-8">

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="stat-card bg-white rounded-2xl p-6 border border-gray-100 shadow-sm slide-up" style="animation-delay:.05s">
        <div class="flex justify-between items-start mb-3">
          <span class="text-xs font-bold uppercase tracking-widest" style="color:var(--muted)">Total Books</span>
          <span style="background:var(--blue-light);color:var(--blue)" class="w-8 h-8 rounded-xl flex items-center justify-center text-sm"><i class="fas fa-book"></i></span>
        </div>
        <p class="syne text-3xl font-extrabold" style="color:var(--ink)"><%= books.length %></p>
        <p class="text-xs mt-1" style="color:var(--muted)"><%= books.filter(b=>b.isPremium).length %> premium</p>
      </div>
      <div class="stat-card bg-white rounded-2xl p-6 border border-gray-100 shadow-sm slide-up" style="animation-delay:.1s">
        <div class="flex justify-between items-start mb-3">
          <span class="text-xs font-bold uppercase tracking-widest" style="color:var(--muted)">Members</span>
          <span style="background:var(--purple-light);color:var(--purple)" class="w-8 h-8 rounded-xl flex items-center justify-center text-sm"><i class="fas fa-users"></i></span>
        </div>
        <p class="syne text-3xl font-extrabold" style="color:var(--ink)"><%= stats.userCount %></p>
        <p class="text-xs mt-1" style="color:var(--muted)"><%= users.filter(u=>u.isPremium).length %> premium</p>
      </div>
      <div class="stat-card bg-white rounded-2xl p-6 border border-gray-100 shadow-sm slide-up" style="animation-delay:.15s">
        <div class="flex justify-between items-start mb-3">
          <span class="text-xs font-bold uppercase tracking-widest" style="color:var(--muted)">Active Books</span>
          <span style="background:var(--green-light);color:var(--green)" class="w-8 h-8 rounded-xl flex items-center justify-center text-sm"><i class="fas fa-check-circle"></i></span>
        </div>
        <p class="syne text-3xl font-extrabold" style="color:var(--ink)"><%= books.filter(b=>b.isActive).length %></p>
        <p class="text-xs mt-1" style="color:var(--muted)"><%= books.filter(b=>!b.isActive).length %> archived</p>
      </div>
      <div class="stat-card bg-white rounded-2xl p-6 border border-gray-100 shadow-sm slide-up" style="animation-delay:.2s">
        <div class="flex justify-between items-start mb-3">
          <span class="text-xs font-bold uppercase tracking-widest" style="color:var(--muted)">Communities</span>
          <span style="background:var(--amber-light);color:var(--amber)" class="w-8 h-8 rounded-xl flex items-center justify-center text-sm"><i class="fas fa-comments"></i></span>
        </div>
        <p class="syne text-3xl font-extrabold" style="color:var(--ink)"><%= stats.communityCount %></p>
        <p class="text-xs mt-1" style="color:var(--muted)">Reading circles</p>
      </div>
    </div>

  
    <div class="flex gap-2 mb-6 bg-white p-1.5 rounded-2xl border border-gray-100 shadow-sm w-fit">
      <button onclick="switchTab('books')"   id="tab-books"   class="tab-btn active syne text-sm font-bold px-5 py-2.5 rounded-xl">Books</button>
      <button onclick="switchTab('users')"   id="tab-users"   class="tab-btn syne text-sm font-bold px-5 py-2.5 rounded-xl" style="color:var(--muted)">Members</button>
      <button onclick="switchTab('circles')" id="tab-circles" class="tab-btn syne text-sm font-bold px-5 py-2.5 rounded-xl" style="color:var(--muted)">Communities</button>
      <button onclick="switchTab('push')"    id="tab-push"    class="tab-btn syne text-sm font-bold px-5 py-2.5 rounded-xl" style="color:var(--muted)">
        <i class="fas fa-bell text-xs mr-1"></i> Push
      </button>
    </div>

    <div id="pane-books" class="tab-pane active fade-in">
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">

        <div class="p-6 border-b border-gray-50 flex flex-wrap items-center justify-between gap-3">
          <h2 class="syne text-lg font-extrabold" style="color:var(--ink)">Book Catalog</h2>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="relative">
              <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
              <input id="bookSearch" oninput="filterBooks()" placeholder="Search title or author…" 
                     class="search-input pl-8 pr-4 py-2 rounded-xl text-sm border border-gray-200 w-56 bg-gray-50">
            </div>
            <select id="bookFilter" onchange="filterBooks()" class="search-input text-sm border border-gray-200 rounded-xl px-3 py-2 bg-gray-50">
              <option value="all">All Books</option>
              <option value="premium">Premium Only</option>
              <option value="free">Free Only</option>
              <option value="inactive">Archived</option>
            </select>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left" id="booksTable">
            <thead>
              <tr style="background:var(--surface)">
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Book</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Category</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Price</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Rating</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Premium</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">
                  Status
                  <span title="Toggle OFF = book is archived and hidden from catalog" class="ml-1 cursor-help opacity-50">ⓘ</span>
                </th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">PDF</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Actions</th>
              </tr>
            </thead>
            <tbody id="booksBody">
              <% books.forEach(book => { %>
              <tr class="data-row border-t border-gray-50" 
                  data-title="<%= book.title.toLowerCase() %>" 
                  data-author="<%= book.author.toLowerCase() %>"
                  data-premium="<%= book.isPremium %>"
                  data-active="<%= book.isActive %>">
                
                <td class="px-6 py-3">
                  <div class="flex items-center gap-4">
                    <img src="<%= book.image %>" alt="" 
                         class="w-14 h-18 object-cover rounded-xl shadow-sm flex-shrink-0"
                         style="height:72px;width:52px"
                         onerror="this.src='/uploads/default-book.png'">
                    <div>
                      <p class="font-black text-base leading-snug" style="color:var(--ink);max-width:200px" title="<%= book.title %>">
                        <%= book.title.length > 28 ? book.title.substring(0,28)+'…' : book.title %>
                      </p>
                      <p class="text-xs font-medium mt-0.5" style="color:var(--muted)">by <%= book.author %></p>
                      <p class="text-[10px] font-bold uppercase tracking-widest mt-1" style="color:#94a3b8">ISBN: <%= book.isbn %></p>
                    </div>
                  </div>
                </td>

                <td class="px-6 py-3">
                  <span class="badge" style="background:var(--blue-light);color:var(--blue)"><%= book.category %></span>
                </td>

                <td class="px-6 py-3">
                  <div class="flex items-center gap-1">
                    <span class="text-xs font-bold" style="color:var(--muted)">$</span>
                    <input type="number" 
                           class="inline-edit font-bold text-sm w-16" 
                           style="color:var(--ink)"
                           value="<%= book.price %>" 
                           step="0.01" min="0"
                           onblur="updatePrice('<%= book._id %>', this.value)"
                           onkeydown="if(event.key==='Enter')this.blur()">
                  </div>
                </td>

                <td class="px-6 py-3">
                  <div class="flex items-center gap-1">
                    <i class="fas fa-star text-amber-400 text-xs"></i>
                    <input type="number" 
                           class="inline-edit font-bold text-sm w-10" 
                           style="color:var(--ink)"
                           value="<%= book.averageRating ? book.averageRating.toFixed(1) : '5.0' %>" 
                           step="0.1" min="1" max="5"
                           onblur="updateRating('<%= book._id %>', this.value)"
                           onkeydown="if(event.key==='Enter')this.blur()">
                  </div>
                </td>

                <td class="px-6 py-3">
                  <div id="premium-track-<%= book._id %>" 
                       onclick="toggleBookPremium('<%= book._id %>', this)"
                       class="toggle-track <%= book.isPremium ? 'on' : 'off' %>">
                    <div class="toggle-thumb"></div>
                  </div>
                </td>

                <td class="px-6 py-3">
                  <div class="flex flex-col gap-1.5">
                    <span id="status-badge-<%= book._id %>"
                          class="badge w-fit <%= book.isActive ? '' : '' %>"
                          style="background:<%= book.isActive ? 'var(--green-light)' : '#f1f5f9' %>;color:<%= book.isActive ? 'var(--green)' : '#64748b' %>">
                      <i class="fas <%= book.isActive ? 'fa-circle-check' : 'fa-archive' %>"></i>
                      <%= book.isActive ? 'Active' : 'Archived' %>
                    </span>
                    <div id="status-track-<%= book._id %>"
                         onclick="toggleBookStatus('<%= book._id %>', this)"
                         class="toggle-track <%= book.isActive ? 'on' : 'off' %>"
                         style="<%= book.isActive ? 'background:var(--green)' : '' %>"
                         title="<%= book.isActive ? 'Click to archive' : 'Click to activate' %>">
                      <div class="toggle-thumb"></div>
                    </div>
                  </div>
                </td>

                <td class="px-6 py-3">
                  <% if (book.pdfPath) { %>
                    <span class="badge" style="background:var(--green-light);color:var(--green)"><i class="fas fa-check"></i> Linked</span>
                  <% } else { %>
                    <span class="badge" style="background:var(--red-light);color:var(--red)"><i class="fas fa-times"></i> Missing</span>
                  <% } %>
                </td>

                <td class="px-6 py-3">
                  <div class="relative" id="action-wrap-<%= book._id %>">
                    <button onclick="toggleActionMenu('<%= book._id %>')"
                            class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50"
                            style="border-color:var(--border);color:var(--ink)">
                      Actions <i class="fas fa-chevron-down text-[9px]"></i>
                    </button>
                    <div id="action-menu-<%= book._id %>"
                         class="hidden absolute right-0 top-full mt-1 w-44 bg-white rounded-2xl shadow-xl border overflow-hidden z-30"
                         style="border-color:var(--border)">
                      <button onclick="openEditBookModal(<%= JSON.stringify(book) %>); closeActionMenu('<%= book._id %>')"
                              class="w-full flex items-center gap-2.5 px-4 py-2.5 text-xs font-semibold text-slate-700 hover:bg-blue-50 hover:text-blue-600 transition-colors text-left">
                        <i class="fas fa-pen w-4 text-center text-blue-400"></i> Edit Details
                      </button>
                      <button onclick="uploadPdf('<%= book._id %>', '<%= book.title.replace(/'/g,'') %>', '<%= book.pdfPath || '' %>'); closeActionMenu('<%= book._id %>')"
                              class="w-full flex items-center gap-2.5 px-4 py-2.5 text-xs font-semibold text-slate-700 hover:bg-purple-50 hover:text-purple-600 transition-colors text-left">
                        <i class="fas fa-file-pdf w-4 text-center text-purple-400"></i>
                        <%= book.pdfPath ? 'Manage PDF' : 'Upload PDF' %>
                      </button>
                      <div class="border-t" style="border-color:var(--border)">
                        <button onclick="confirmDeleteBook('<%= book._id %>', '<%= book.title.replace(/'/g,'') %>'); closeActionMenu('<%= book._id %>')"
                                class="w-full flex items-center gap-2.5 px-4 py-2.5 text-xs font-semibold text-red-500 hover:bg-red-50 transition-colors text-left">
                          <i class="fas fa-archive w-4 text-center"></i> Archive Book
                        </button>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="pane-users" class="tab-pane fade-in">
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">

        <div class="p-6 border-b border-gray-50 flex flex-wrap items-center justify-between gap-3">
          <h2 class="syne text-lg font-extrabold" style="color:var(--ink)">Member Access Control</h2>
          <div class="relative">
            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
            <input id="userSearch" oninput="filterUsers()" placeholder="Search members…" 
                   class="search-input pl-8 pr-4 py-2 rounded-xl text-sm border border-gray-200 w-56 bg-gray-50">
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr style="background:var(--surface)">
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Member</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Joined</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Verified</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Premium</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Library</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Actions</th>
              </tr>
            </thead>
            <tbody id="usersBody">
              <% users.filter(u => u.role !== 'admin').forEach(user => { %>
              <tr class="data-row border-t border-gray-50" data-name="<%= user.username.toLowerCase() %>" data-email="<%= user.email.toLowerCase() %>">
                
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full flex items-center justify-center font-black text-sm text-white flex-shrink-0"
                         style="background: hsl(<%= Math.abs(user.username.charCodeAt(0) * 137) % 360 %>, 60%, 50%)">
                      <%= user.username.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                      <p class="font-bold text-sm" style="color:var(--ink)"><%= user.username %></p>
                      <p class="text-xs" style="color:var(--muted)"><%= user.email %></p>
                    </div>
                  </div>
                </td>

                <td class="px-6 py-4">
                  <p class="text-sm" style="color:var(--muted)"><%= new Date(user.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></p>
                </td>

                <td class="px-6 py-4">
                  <% if (user.isVerified) { %>
                    <span class="badge" style="background:var(--green-light);color:var(--green)"><i class="fas fa-check mr-1"></i>Verified</span>
                  <% } else { %>
                    <span class="badge" style="background:var(--red-light);color:var(--red)">Unverified</span>
                  <% } %>
                </td>

                <td class="px-6 py-4">
                  <div id="user-premium-track-<%= user._id %>" 
                       onclick="toggleUserPremium('<%= user._id %>', this)"
                       class="toggle-track <%= user.isPremium ? 'on' : 'off' %>">
                    <div class="toggle-thumb"></div>
                  </div>
                </td>

                <td class="px-6 py-4">
                  <span class="badge" style="background:var(--blue-light);color:var(--blue)">
                    <%= user.library ? user.library.length : 0 %> books
                  </span>
                </td>

                <td class="px-6 py-4">
                  <div class="relative" id="user-action-wrap-<%= user._id %>">
                    <button onclick="toggleUserActionMenu('<%= user._id %>')"
                            class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50"
                            style="border-color:var(--border);color:var(--ink)">
                      Actions <i class="fas fa-chevron-down text-[9px]"></i>
                    </button>
                    <div id="user-action-menu-<%= user._id %>"
                         class="hidden absolute right-0 top-full mt-1 w-44 bg-white rounded-2xl shadow-xl border overflow-hidden z-30"
                         style="border-color:var(--border)">
                      <button onclick="viewUserLibrary('<%= user._id %>', '<%= user.username %>'); closeUserActionMenu('<%= user._id %>')"
                              class="w-full flex items-center gap-2.5 px-4 py-2.5 text-xs font-semibold text-slate-700 hover:bg-blue-50 hover:text-blue-600 transition-colors text-left">
                        <i class="fas fa-book-open w-4 text-center text-blue-400"></i> View Library
                      </button>
                      <button onclick="toggleUserPremiumFromMenu('<%= user._id %>'); closeUserActionMenu('<%= user._id %>')"
                              class="w-full flex items-center gap-2.5 px-4 py-2.5 text-xs font-semibold text-slate-700 hover:bg-amber-50 hover:text-amber-600 transition-colors text-left">
                        <i class="fas fa-crown w-4 text-center text-amber-400"></i>
                        <%= user.isPremium ? 'Revoke Premium' : 'Grant Premium' %>
                      </button>
                      <div class="border-t" style="border-color:var(--border)">
                        <button onclick="confirmDeleteUser('<%= user._id %>', '<%= user.username %>'); closeUserActionMenu('<%= user._id %>')"
                                class="w-full flex items-center gap-2.5 px-4 py-2.5 text-xs font-semibold text-red-500 hover:bg-red-50 transition-colors text-left">
                          <i class="fas fa-ban w-4 text-center"></i> Ban Member
                        </button>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="pane-circles" class="tab-pane fade-in">
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">

        <div class="p-6 border-b border-gray-50 flex flex-wrap items-center justify-between gap-3">
          <h2 class="syne text-lg font-extrabold" style="color:var(--ink)">Reading Communities</h2>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="relative">
              <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-xs"></i>
              <input id="circleSearch" oninput="filterCircles()" placeholder="Search communities…"
                     class="search-input pl-8 pr-4 py-2 rounded-xl text-sm border border-gray-200 w-52 bg-gray-50">
            </div>
            <select id="circleFilter" onchange="filterCircles()" class="search-input text-sm border border-gray-200 rounded-xl px-3 py-2 bg-gray-50">
              <option value="all">All Categories</option>
              <option value="Tech">Tech</option>
              <option value="Design">Design</option>
              <option value="Computer Science">Computer Science</option>
              <option value="Fiction">Fiction</option>
            </select>
            <button onclick="openCreateCircleModal()"
                    class="pill-btn text-white px-4 py-2 text-xs flex items-center gap-1.5" style="background:var(--purple)">
              <i class="fas fa-plus"></i> New Circle
            </button>
            <button onclick="openCreateSuperCommunityModal()"
                    class="pill-btn text-white px-4 py-2 text-xs flex items-center gap-1.5" style="background:var(--amber)">
              <i class="fas fa-star"></i> New Super Circle
            </button>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr style="background:var(--surface)">
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Community</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Category</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Members</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Posts</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Created</th>
                <th class="px-6 py-4 text-xs font-black uppercase tracking-widest" style="color:var(--muted)">Actions</th>
              </tr>
            </thead>
            <tbody id="circlesBody">
              <% stats.recentCircles.forEach(circle => { %>
              <tr class="data-row border-t border-gray-50"
                  data-name="<%= circle.name.toLowerCase() %>"
                  data-category="<%= circle.category %>">
                
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-black text-sm flex-shrink-0"
                         style="background: hsl(<%= Math.abs(circle.name.charCodeAt(0) * 97) % 360 %>, 55%, 48%)">
                      <%= circle.name.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                      <p class="font-bold text-sm flex items-center gap-1.5" style="color:var(--ink)">
                        <% if (circle.isSuper) { %><i class="fas fa-star text-amber-400 text-xs"></i><% } %>
                        <%= circle.name %>
                        <% if (circle.isSuper) { %>
                          <span class="badge" style="background:var(--amber-light);color:var(--amber)">Super</span>
                        <% } %>
                      </p>
                      <p class="text-xs line-clamp-1 max-w-xs" style="color:var(--muted)"><%= circle.description %></p>
                    </div>
                  </div>
                </td>

                <td class="px-6 py-4">
                  <span class="badge" style="background:var(--purple-light);color:var(--purple)"><%= circle.category %></span>
                </td>

                <td class="px-6 py-4">
                  <span class="badge" style="background:var(--blue-light);color:var(--blue)">
                    <i class="fas fa-users"></i> <%= circle.members ? circle.members.length : 0 %>
                  </span>
                </td>

                <td class="px-6 py-4">
                  <span class="badge" style="background:var(--green-light);color:var(--green)">
                    <i class="fas fa-comments"></i> <%= circle.posts ? circle.posts.length : 0 %>
                  </span>
                </td>

                <td class="px-6 py-4">
                  <p class="text-xs" style="color:var(--muted)">
                    <%= new Date(circle.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %>
                  </p>
                </td>

                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <a href="/communities/<%= circle._id %>"
                       class="pill-btn text-white text-xs px-3 py-1.5" style="background:var(--blue)">
                      <i class="fas fa-eye"></i>
                    </a>
                    <button onclick="openEditCircleModal('<%= circle._id %>', '<%= circle.name.replace(/'/g, '') %>', '<%= circle.description.replace(/'/g, '') %>', '<%= circle.category %>')"
                            class="pill-btn text-white text-xs px-3 py-1.5" style="background:var(--amber)">
                      <i class="fas fa-pen"></i>
                    </button>
                    <button onclick="confirmDeleteCircle('<%= circle._id %>', '<%= circle.name.replace(/'/g, '') %>')"
                            class="pill-btn text-white text-xs px-3 py-1.5" style="background:var(--red)">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              <% }) %>
              <% if (!stats.recentCircles || stats.recentCircles.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-16 text-center text-sm font-bold" style="color:var(--muted)">
                  No communities yet. Create the first one!
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="pane-push" class="tab-pane fade-in">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-8">
          <h2 class="syne text-lg font-extrabold mb-1" style="color:var(--ink)">
            <i class="fas fa-paper-plane mr-2" style="color:var(--blue)"></i>Broadcast Notification
          </h2>
          <p class="text-xs mb-6" style="color:var(--muted)">Send a push notification to all subscribed users instantly.</p>
          <form id="pushBroadcastForm" class="space-y-4">
            <div>
              <label class="block text-xs font-black uppercase tracking-wider mb-1.5" style="color:var(--muted)">Title *</label>
              <input id="pushTitle" required placeholder="📚 New Book Added to BookVault!"
                     class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs font-black uppercase tracking-wider mb-1.5" style="color:var(--muted)">Message *</label>
              <textarea id="pushBody" required rows="3" placeholder="Check out the latest additions to the vault..."
                        class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"></textarea>
            </div>
            <div>
              <label class="block text-xs font-black uppercase tracking-wider mb-1.5" style="color:var(--muted)">Link URL (optional)</label>
              <input id="pushUrl" placeholder="/books" value="/books"
                     class="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div id="pushResult" class="hidden p-3 rounded-xl text-xs font-bold"></div>
            <button type="submit" id="pushSendBtn"
                    class="w-full py-3.5 rounded-2xl font-black text-white text-sm flex items-center justify-center gap-2 transition-all active:scale-95"
                    style="background:var(--blue)">
              <i class="fas fa-paper-plane"></i> Send to All Subscribers
            </button>
          </form>
        </div>

        <div class="space-y-4">
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-black uppercase tracking-wider mb-2" style="color:var(--blue)">
              <i class="fas fa-info-circle mr-1"></i> How it works
            </p>
            <p class="text-sm leading-relaxed" style="color:var(--ink)">
              Notifications are sent to all users who clicked the <strong>bell icon</strong> in the navbar and granted browser permission. They appear even when BookVault is closed.
            </p>
          </div>
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-black uppercase tracking-wider mb-2" style="color:var(--green)">
              <i class="fas fa-bolt mr-1"></i> Auto-triggered
            </p>
            <p class="text-sm leading-relaxed" style="color:var(--ink)">
              A notification is <strong>automatically sent</strong> to all subscribers whenever you add a new book through the Books tab.
            </p>
          </div>
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-black uppercase tracking-wider mb-2" style="color:var(--amber)">
              <i class="fas fa-key mr-1"></i> Setup Required
            </p>
            <p class="text-sm leading-relaxed" style="color:var(--ink)">
              Ensure <code class="bg-gray-100 px-1 rounded text-xs">VAPID_PUBLIC_KEY</code>, <code class="bg-gray-100 px-1 rounded text-xs">VAPID_PRIVATE_KEY</code>, and <code class="bg-gray-100 px-1 rounded text-xs">VAPID_EMAIL</code> are set in your Render environment variables.
            </p>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>


<div id="addBookModal" class="modal-wrap fixed inset-0 z-[200] hidden items-center justify-center p-4 bg-gray-900/50" style="display:none">
