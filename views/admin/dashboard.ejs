          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center text-white text-sm" style="background:var(--amber)">
              <i class="fas fa-crown"></i>
            </div>
            <div>
              <p class="text-sm font-bold" style="color:var(--ink)">Premium Asset</p>
              <p class="text-xs" style="color:var(--muted)">Only premium members can download</p>
