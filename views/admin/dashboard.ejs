        const errText = await res.text();
        throw new Error(`Server responded ${res.status}: ${errText}`);
      }
      const data = await res.json();
      if (data.success) {
        closeModal('createCircleModal');
        Toast.fire({ icon:'success', title:'Community created!' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Creation failed' });
        btn.disabled = false; btn.textContent = 'Create Community';
      }
    } catch(err) {
      console.error('createCircle error:', err);
      btn.disabled = false; btn.textContent = 'Create Community';
      Toast.fire({ icon:'error', title: err.message || 'Network error — check server logs' });
    }
  });

 
