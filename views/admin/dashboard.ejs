<script>
  const Toast = Swal.mixin({ toast:true, position:'top-end', showConfirmButton:false, timer:3000, timerProgressBar:true });

  function switchTab(name) {
    ['books','users','circles','push'].forEach(t => {
      document.getElementById(`tab-${t}`).classList.toggle('active', t === name);
      document.getElementById(`tab-${t}`).style.color = t === name ? '' : 'var(--muted)';
      document.getElementById(`pane-${t}`).classList.toggle('active', t === name);
    });
  }

  document.getElementById('pushBroadcastForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('pushSendBtn');
    const result = document.getElementById('pushResult');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Sending...';

    const payload = {
      title: document.getElementById('pushTitle').value.trim(),
      body:document.getElementById('pushBody').value.trim(),
      url: document.getElementById('pushUrl').value.trim() || '/books'
    };

    try {
      const res  = await fetch('/push/send-to-all', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      result.classList.remove('hidden');
      if (data.success) {
        result.style.background = 'var(--green-light)';
        result.style.color = 'var(--green)';
        result.textContent = `✅ Sent to ${data.sent} subscriber${data.sent !== 1 ? 's' : ''}${data.failed > 0 ? ` (${data.failed} failed/expired)` : ''}.`;
        document.getElementById('pushBroadcastForm').reset();
        document.getElementById('pushUrl').value = '/books';
      } else {
        result.style.background = 'var(--red-light)';
        result.style.color = 'var(--red)';
        result.textContent = `❌ ${data.message || 'Send failed. Check VAPID keys.'}`;
      }
    } catch (err) {
      result.classList.remove('hidden');
      result.style.background = 'var(--red-light)';
      result.style.color  = 'var(--red)';
      result.textContent = '❌ Network error. Please try again.';
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-paper-plane"></i> Send to All Subscribers';
    }
  });

  function openModal(id) {
    const el = document.getElementById(id);
    el.style.display = 'flex';
    el.classList.remove('hidden');
  }
  function closeModal(id) {
    const el = document.getElementById(id);
    el.style.display = 'none';
    el.classList.add('hidden');
  }

  ['addBookModal','editBookModal','uploadPdfModal','createCircleModal','editCircleModal','superCommunityModal'].forEach(id => {
    document.getElementById(id).addEventListener('click', function(e) {
      if (e.target === this) closeModal(id);
    });
  });
  function openAddBookModal() { openModal('addBookModal'); }

  document.getElementById('addBookForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('addBookSubmitBtn');
    btn.disabled = true; btn.textContent = 'Publishing...';
    const fd = new FormData(e.target);
    fd.set('isPremium', document.getElementById('addIsPremium').checked ? 'true' : 'false');
    fd.set('isActive', 'true');
    try {
      const res  = await fetch('/books/add', { method:'POST', body: fd, credentials:'include' });
      const data = await res.json();
      if (data.success) {
        Swal.fire({ icon:'success', title:'Published!', text:'Book added to vault.' })
          .then(() => location.reload());
      } else {
        Swal.fire({ icon:'error', title:'Error', text: data.message });
        btn.disabled = false; btn.textContent = 'Publish to Library Vault';
      }
    } catch (err) {
      btn.disabled = false; btn.textContent = 'Publish to Library Vault';
      Toast.fire({ icon:'error', title:'Network error' });
    }
  });


  function openEditBookModal(book) {
    document.getElementById('editBookId').value        = book._id;
    document.getElementById('editBookSubtitle').textContent = book.title;
    document.getElementById('editTitle').value         = book.title;
    document.getElementById('editAuthor').value        = book.author;
    document.getElementById('editPrice').value         = book.price;
    document.getElementById('editDescription').value   = book.description || '';
    document.getElementById('editIsPremium').checked   = book.isPremium;
    const sel = document.getElementById('editCategory');
    [...sel.options].forEach(o => o.selected = o.value === book.category);
    openModal('editBookModal');
  }

  document.getElementById('editBookForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('editBookId').value;
    const payload = {
      title:document.getElementById('editTitle').value,
      author: document.getElementById('editAuthor').value,
      price: parseFloat(document.getElementById('editPrice').value) || 0,
      category:  document.getElementById('editCategory').value,
      description: document.getElementById('editDescription').value,
      isPremium: document.getElementById('editIsPremium').checked
    };
    try {
      const res  = await fetch(`/admin/books/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type':'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        closeModal('editBookModal');
        Toast.fire({ icon:'success', title:'Book updated!' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Update failed' });
      }
    } catch(err) {
      Toast.fire({ icon:'error', title:'Network error' });
    }
  });

  
  function toggleActionMenu(bookId) {
    const menu = document.getElementById(`action-menu-${bookId}`);
    // Close all other open menus first
    document.querySelectorAll('[id^="action-menu-"]').forEach(m => {
      if (m.id !== `action-menu-${bookId}`) m.classList.add('hidden');
    });
    document.querySelectorAll('[id^="user-action-menu-"]').forEach(m => m.classList.add('hidden'));
    menu.classList.toggle('hidden');
  }
  function closeActionMenu(bookId) {
    document.getElementById(`action-menu-${bookId}`)?.classList.add('hidden');
  }
  function toggleUserActionMenu(userId) {
    const menu = document.getElementById(`user-action-menu-${userId}`);
    document.querySelectorAll('[id^="user-action-menu-"]').forEach(m => {
      if (m.id !== `user-action-menu-${userId}`) m.classList.add('hidden');
    });
    document.querySelectorAll('[id^="action-menu-"]').forEach(m => m.classList.add('hidden'));
    menu.classList.toggle('hidden');
  }
  function closeUserActionMenu(userId) {
    document.getElementById(`user-action-menu-${userId}`)?.classList.add('hidden');
  }
  document.addEventListener('click', (e) => {
    if (!e.target.closest('[id^="action-wrap-"]') && !e.target.closest('[id^="user-action-wrap-"]')) {
      document.querySelectorAll('[id^="action-menu-"]').forEach(m => m.classList.add('hidden'));
      document.querySelectorAll('[id^="user-action-menu-"]').forEach(m => m.classList.add('hidden'));
    }
  });

  function uploadPdf(bookId, title, currentPdfPath) {
    document.getElementById('uploadPdfBookId').value = bookId;
    document.getElementById('uploadPdfSubtitle').textContent = title;
    document.getElementById('pdfFileInput').value = '';
    document.getElementById('pdfFileName').textContent = '';
    document.getElementById('pdfFileName').classList.add('hidden');

    const existing = document.getElementById('existingPdfSection');
    const noPdf= document.getElementById('noPdfSection');
    if (currentPdfPath && currentPdfPath !== '') {
      existing.classList.remove('hidden');
      noPdf.classList.add('hidden');
      const fname = currentPdfPath.split('/').pop();
      document.getElementById('existingPdfName').textContent = fname;
      existing.dataset.pdfPath = currentPdfPath;
      existing.dataset.bookId  = bookId;
    } else {
      existing.classList.add('hidden');
      noPdf.classList.remove('hidden');
    }

    openModal('uploadPdfModal');
  }

  function updatePdfLabel(input) {
    const label = document.getElementById('pdfFileName');
    if (input.files[0]) {
      label.textContent = input.files[0].name;
      label.classList.remove('hidden');
    } else {
      label.classList.add('hidden');
    }
  }

  async function deletePdf() {
    const section = document.getElementById('existingPdfSection');
    const bookId  = section.dataset.bookId;

    const result = await Swal.fire({
      title: 'Remove this PDF?',
      text: 'The file link will be removed from this book.',
      icon: 'warning', showCancelButton: true,
      confirmButtonText: 'Remove', confirmButtonColor: '#ef4444'
    });
    if (!result.isConfirmed) return;

    try {
      const res  = await fetch(`/admin/books/${bookId}/delete-pdf`, {
        method: 'DELETE', credentials: 'include'
      });
      const data = await res.json();
      if (data.success) {
        closeModal('uploadPdfModal');
        Toast.fire({ icon: 'success', title: 'PDF removed' });
        setTimeout(() => location.reload(), 700);
      } else {
        Toast.fire({ icon: 'error', title: data.message || 'Remove failed' });
      }
    } catch(e) {
      Toast.fire({ icon: 'error', title: 'Network error' });
    }
  }

  document.getElementById('uploadPdfForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const file = document.getElementById('pdfFileInput').files[0];
    if (!file) { Toast.fire({ icon: 'warning', title: 'Please select a PDF file' }); return; }

    const id  = document.getElementById('uploadPdfBookId').value;
    const btn = document.getElementById('uploadPdfBtn');
    btn.disabled = true; btn.textContent = 'Uploading...';

    const fd = new FormData();
    fd.append('bookPdf', file);
    try {
      const res  = await fetch(`/admin/books/${id}/upload-pdf`, { method:'POST', body:fd, credentials:'include' });
      const data = await res.json();
      if (data.success) {
        closeModal('uploadPdfModal');
        Toast.fire({ icon:'success', title:'PDF linked successfully!' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Upload failed' });
        btn.disabled = false; btn.innerHTML = '<i class="fas fa-upload mr-2"></i> Upload & Link PDF';
      }
    } catch(err) {
      Toast.fire({ icon:'error', title:'Network error' });
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-upload mr-2"></i> Upload & Link PDF';
    }
  });

  async function toggleBookStatus(bookId, track) {
    const isOn= track.classList.contains('on');
    try {
      const res= await fetch(`/books/${bookId}/status`, {
        method:'PATCH', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify({ isActive: !isOn })
      });
      const data = await res.json();
      if (data.success) {
        track.classList.toggle('on', !isOn);
        track.classList.toggle('off', isOn);
        track.style.background = !isOn ? 'var(--green)' : '';
        track.title = !isOn ? 'Click to archive' : 'Click to activate';
        const badge = document.getElementById(`status-badge-${bookId}`);
        if (badge) {
          badge.innerHTML = !isOn
            ? '<i class="fas fa-circle-check"></i> Active'
            : '<i class="fas fa-archive"></i> Archived';
          badge.style.background  = !isOn ? 'var(--green-light)' : '#f1f5f9';
          badge.style.color       = !isOn ? 'var(--green)'       : '#64748b';
        }
        Toast.fire({ icon:'success', title: !isOn ? 'Book activated' : 'Book archived' });
      }
    } catch(e) { Toast.fire({ icon:'error', title:'Toggle failed' }); }
  }
  async function toggleUserPremiumFromMenu(userId) {
    const track = document.getElementById(`user-premium-track-${userId}`);
    if (track) {
      toggleUserPremium(userId, track);
    } else {
      try {
        const res = await fetch(`/admin/toggle-premium/${userId}`, { method:'POST', credentials:'include' });
        const data= await res.json();
        if (data.success) {
          Toast.fire({ icon:'success', title: data.isPremium ? 'Upgraded to Premium' : 'Reverted to Free' });
          setTimeout(() => location.reload(), 800);
        }
      } catch(e) { Toast.fire({ icon:'error', title:'Toggle failed' }); }
    }
  }

  async function updatePrice(bookId, value) {
    const price= parseFloat(value);
    if (isNaN(price) || price < 0) return;
    try {
      const res= await fetch(`/admin/books/${bookId}`, {
        method:'PATCH', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify({ price })
      });
      const data = await res.json();
      if (data.success) Toast.fire({ icon:'success', title:'Price updated' });
    } catch(e) { Toast.fire({ icon:'error', title:'Failed to update price' }); }
  }

  
  async function updateRating(bookId, value) {
    const rating = parseFloat(value);
    if (isNaN(rating) || rating < 1 || rating > 5) return;
    try {
      const res  = await fetch(`/admin/books/${bookId}`, {
        method:'PATCH', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify({ averageRating: rating })
      });
      const data = await res.json();
      if (data.success) Toast.fire({ icon:'success', title:'Rating updated' });
    } catch(e) { Toast.fire({ icon:'error', title:'Failed to update rating' }); }
  }

  // ── TOGGLE BOOK PREMIUM ────────────────────────────────────────────────────
  async function toggleBookPremium(bookId, track) {
    const isOn = track.classList.contains('on');
    try {
      const res  = await fetch(`/books/${bookId}/premium`, {
        method:'PATCH', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify({ isPremium: !isOn })
      });
      const data = await res.json();
      if (data.success) {
        track.classList.toggle('on', !isOn);
        track.classList.toggle('off', isOn);
        Toast.fire({ icon:'success', title: !isOn ? 'Marked Premium' : 'Marked Free' });
      }
    } catch(e) { Toast.fire({ icon:'error', title:'Toggle failed' }); }
  }


  async function toggleUserPremium(userId, track) {
    const isOn = track.classList.contains('on');
    try {
      const res  = await fetch(`/admin/toggle-premium/${userId}`, { method:'POST', credentials:'include' });
      const data = await res.json();
      if (data.success) {
        track.classList.toggle('on', !isOn);
        track.classList.toggle('off', isOn);
        Toast.fire({ icon:'success', title: data.isPremium ? 'Upgraded to Premium' : 'Reverted to Free' });
      }
    } catch(e) { Toast.fire({ icon:'error', title:'Toggle failed' }); }
  }

  async function confirmDeleteBook(bookId, title) {
    const result = await Swal.fire({
      title: `Archive "${title}"?`,
      text: 'This will deactivate the book from the catalog.',
      icon: 'warning', showCancelButton:true,
      confirmButtonText:'Archive', confirmButtonColor: '#ef4444'
    });
    if (result.isConfirmed) {
      const res  = await fetch(`/books/deactivate/${bookId}`, { method:'PATCH', credentials:'include' });
      const data = await res.json();
      if (data.success) { Toast.fire({ icon:'success', title:'Book archived' }); setTimeout(()=>location.reload(),800); }
    }
  }

  async function confirmDeleteUser(userId, username) {
    const result = await Swal.fire({
      title: `Ban "${username}"?`,
      text: 'This will remove their account.',
      icon: 'warning', showCancelButton:true,
      confirmButtonText:'Confirm Ban', confirmButtonColor: '#ef4444'
    });
    if (result.isConfirmed) {
      const res  = await fetch(`/admin/users/${userId}`, { method:'DELETE', credentials:'include' });
      const data = await res.json();
      if (data.success) { Toast.fire({ icon:'success', title:'User removed' }); setTimeout(()=>location.reload(),800); }
    }
  }


  async function confirmDeleteCircle(id, name) {
    const result = await Swal.fire({
      title: `Terminate "${name}"?`,
      text: 'All posts inside will be permanently deleted.',
      icon:'warning', showCancelButton:true,
      confirmButtonText:'Terminate', confirmButtonColor:'#ef4444'
    });
    if (result.isConfirmed) {
      const res= await fetch(`/admin/communities/${id}`, { method:'DELETE', credentials:'include' });
      const data = await res.json();
      if (data.success) {
        Toast.fire({ icon:'success', title:'Community removed' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Delete failed' });
      }
    }
  }

  function openCreateCircleModal() { openModal('createCircleModal'); }

  document.getElementById('createCircleForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('createCircleBtn');
    btn.disabled = true; btn.textContent = 'Creating...';
    const payload = {
      name: document.getElementById('newCircleName').value.trim(),
      category: document.getElementById('newCircleCategory').value,
      description: document.getElementById('newCircleDesc').value.trim()
    };
    try {
      const res= await fetch('/communities/create', {
        method:'POST', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        closeModal('createCircleModal');
        Toast.fire({ icon:'success', title:'Community created!' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Creation failed' });
        btn.disabled = false; btn.textContent = 'Create Community';
      }
    } catch(err) {
      btn.disabled = false; btn.textContent = 'Create Community';
      Toast.fire({ icon:'error', title:'Network error' });
    }
  });

  function openEditCircleModal(id, name, desc, category) {
    document.getElementById('editCircleId').value=id;
    document.getElementById('editCircleName').value=name;
    document.getElementById('editCircleDesc').value=desc;
    const sel = document.getElementById('editCircleCategory');
    [...sel.options].forEach(o => o.selected = o.value === category);
    openModal('editCircleModal');
  }

  document.getElementById('editCircleForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('editCircleId').value;
    const payload = {
      name:document.getElementById('editCircleName').value.trim(),
      category:document.getElementById('editCircleCategory').value,
      description:document.getElementById('editCircleDesc').value.trim()
    };
    try {
      const res = await fetch(`/admin/communities/${id}`, {
        method:'PATCH', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        closeModal('editCircleModal');
        Toast.fire({ icon:'success', title:'Community updated!' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Update failed' });
      }
    } catch(err) {
      Toast.fire({ icon:'error', title:'Network error' });
    }
  });

 
  function openCreateSuperCommunityModal() {
    openModal('superCommunityModal');
  }

  document.getElementById('superCommunityForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('superCommunityBtn');
    btn.disabled = true; btn.textContent = 'Creating...';
    const payload = {
      name: document.getElementById('superName').value.trim(),
      category: document.getElementById('superCategory').value,
      description: document.getElementById('superDesc').value.trim()
    };
    try {
      const res  = await fetch('/admin/communities/create-super', {
        method:'POST', headers:{'Content-Type':'application/json'},
        credentials:'include', body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        closeModal('superCommunityModal');
        Toast.fire({ icon:'success', title:'⭐ Super Community created!' });
        setTimeout(() => location.reload(), 800);
      } else {
        Toast.fire({ icon:'error', title: data.message || 'Creation failed' });
        btn.disabled = false; btn.innerHTML = '<i class="fas fa-star mr-2"></i> Create Super Community';
      }
    } catch(err) {
      Toast.fire({ icon:'error', title:'Network error' });
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-star mr-2"></i> Create Super Community';
    }
  });
  function filterCircles() {
    const q = document.getElementById('circleSearch').value.toLowerCase();
    const cat = document.getElementById('circleFilter').value;
    document.querySelectorAll('#circlesBody tr[data-name]').forEach(row => {
      const matchQ = !q  || row.dataset.name.includes(q);
      const matchCat = cat === 'all' || row.dataset.category === cat;
      row.style.display = (matchQ && matchCat) ? '' : 'none';
    });
  }


  function viewUserLibrary(userId, username) {
    window.location.href = `/admin/users/${userId}/library`;
  }

 
  function openAddUserModal() {
    Swal.fire({
      title: 'Promote to Admin',
      html: `<input id="adminEmail" class="swal2-input" placeholder="Member email address">`,
      confirmButtonText: 'Promote',
      confirmButtonColor: 'var(--ink)',
      showCancelButton: true,
      preConfirm: () => {
        const email = document.getElementById('adminEmail').value.trim();
        if (!email) { Swal.showValidationMessage('Email required'); return false; }
        return email;
      }
    }).then(async r => {
      if (r.isConfirmed) {
        const res  = await fetch('/admin/promote', {
          method:'POST', headers:{'Content-Type':'application/json'},
          credentials:'include', body: JSON.stringify({ email: r.value })
        });
        const data = await res.json();
        Toast.fire({ icon: data.success ? 'success':'error', title: data.message || (data.success ? 'Promoted!' : 'Failed') });
        if (data.success) setTimeout(()=>location.reload(),800);
      }
    });
  }

  
  function filterBooks() {
    const q  = document.getElementById('bookSearch').value.toLowerCase();
    const filter = document.getElementById('bookFilter').value;
    document.querySelectorAll('#booksBody tr').forEach(row => {
      const matchSearch = !q || row.dataset.title.includes(q) || row.dataset.author.includes(q);
      const matchFilter = filter === 'all'
        || (filter === 'premium' && row.dataset.premium  === 'true')
        || (filter === 'free' && row.dataset.premium  === 'false')
        || (filter === 'inactive' && row.dataset.active   === 'false');
      row.style.display = (matchSearch && matchFilter) ? '' : 'none';
    });
  }

  
  function filterUsers() {
    const q = document.getElementById('userSearch').value.toLowerCase();
    document.querySelectorAll('#usersBody tr').forEach(row => {
      const match = !q || row.dataset.name.includes(q) || row.dataset.email.includes(q);
      row.style.display = match ? '' : 'none';
    });
  }
</script>
