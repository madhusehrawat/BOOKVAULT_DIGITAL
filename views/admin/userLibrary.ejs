<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head', { title: `${targetUser.username}'s Library | Admin` }) %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-slate-100 min-h-screen">
    <%- include('../partials/navbar') %>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">

        <div class="flex items-center gap-4 mb-8">
            <a href="/admin/dashboard"
               class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-500 hover:bg-slate-900 hover:text-white transition-all shadow-sm flex-shrink-0">
                <i class="fas fa-arrow-left text-sm"></i>
            </a>
            <div>
                <p class="text-xs font-black uppercase tracking-widest text-blue-600">Admin · Member Library</p>
                <h1 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight mt-0.5">
                    <%= targetUser.username %>'s Collection
                </h1>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 md:p-6 mb-8 flex flex-wrap items-center gap-4 md:gap-6">
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl flex items-center justify-center font-black text-xl text-white flex-shrink-0"
                 style="background: hsl(<%= Math.abs(targetUser.username.charCodeAt(0) * 137) % 360 %>, 60%, 50%)">
                <%= targetUser.username.charAt(0).toUpperCase() %>
            </div>
            <div class="flex-grow min-w-0">
                <p class="font-black text-slate-900 text-base md:text-lg truncate"><%= targetUser.username %></p>
                <p class="text-slate-500 text-sm truncate"><%= targetUser.email %></p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <span class="px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider
                    <%= targetUser.isPremium ? 'bg-amber-100 text-amber-600' : 'bg-slate-100 text-slate-500' %>">
                    <i class="fas <%= targetUser.isPremium ? 'fa-crown' : 'fa-user' %> mr-1"></i>
                    <%= targetUser.isPremium ? 'Premium' : 'Free' %>
                </span>
                <span class="px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider bg-blue-50 text-blue-600">
                    <i class="fas fa-books mr-1"></i>
                    <%= books.length %> Book<%= books.length !== 1 ? 's' : '' %>
                </span>
                <span class="px-3 py-1.5 rounded-full text-xs font-black uppercase tracking-wider
                    <%= targetUser.isVerified ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-500' %>">
                    <i class="fas <%= targetUser.isVerified ? 'fa-check-circle' : 'fa-times-circle' %> mr-1"></i>
                    <%= targetUser.isVerified ? 'Verified' : 'Unverified' %>
                </span>
            </div>
        </div>

        <% if (books && books.length > 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-5">
                <% books.forEach(book => { %>
                <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden flex flex-col group hover:shadow-lg hover:-translate-y-1 transition-all duration-300">

                    <!-- Cover -->
                    <div class="relative overflow-hidden bg-slate-100" style="aspect-ratio:3/4">
                        <img src="<%= book.image %>" alt="<%= book.title %>"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                             onerror="this.src='/uploads/default-book.png'">

                        <!-- Badges -->
                        <div class="absolute bottom-3 left-3 flex flex-col gap-1.5">
                            <% if (book.isPremium) { %>
                                <span class="px-2 py-1 bg-amber-500/90 text-white text-[9px] font-black uppercase rounded-lg flex items-center gap-1 w-fit backdrop-blur-sm shadow-sm">
                                    <i class="fas fa-crown"></i> Premium
                                </span>
                            <% } %>
                            <span class="px-2 py-1 bg-blue-600/90 text-white text-[10px] font-black uppercase rounded-lg w-fit backdrop-blur-sm shadow-sm">
                                <%= book.category %>
                            </span>
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="p-4 flex flex-col flex-grow">
                        <h3 class="font-black text-slate-900 text-sm leading-snug line-clamp-2 mb-1 group-hover:text-blue-600 transition-colors">
                            <%= book.title %>
                        </h3>
                        <p class="text-slate-400 text-xs mb-3">by <%= book.author %></p>

                        <!-- Rating + Price -->
                        <div class="flex items-center justify-between mt-auto pt-3 border-t border-slate-50">
                            <div class="flex items-center gap-1">
                                <i class="fas fa-star text-amber-400 text-xs"></i>
                                <span class="text-xs font-black text-slate-700">
                                    <%= book.averageRating ? book.averageRating.toFixed(1) : '5.0' %>
                                </span>
                            </div>
                            <% if (book.price && book.price > 0) { %>
                                <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-lg">
                                    Worth $<%= book.price.toFixed(2) %>
                                </span>
                            <% } else { %>
                                <span class="text-xs font-bold text-blue-500 bg-blue-50 px-2 py-0.5 rounded-lg">Free</span>
                            <% } %>
                        </div>

                        <!-- PDF status -->
                        <div class="mt-3">
                            <% if (book.pdfPath) { %>
                                <span class="w-full flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-black bg-green-50 text-green-600">
                                    <i class="fas fa-check-circle"></i> PDF Linked
                                </span>
                            <% } else { %>
                                <span class="w-full flex items-center justify-center gap-1.5 py-2 rounded-xl text-xs font-black bg-red-50 text-red-400">
                                    <i class="fas fa-times-circle"></i> No PDF
                                </span>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>

        <% } else { %>
            <!-- Empty state -->
            <div class="text-center py-24 bg-white rounded-3xl border border-slate-100 shadow-sm">
                <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <i class="far fa-bookmark text-slate-200 text-2xl"></i>
                </div>
                <h2 class="text-xl font-black text-slate-900">No books saved yet</h2>
                <p class="text-slate-400 text-sm mt-2 mb-6">
                    <%= targetUser.username %> hasn't added any books to their library.
                </p>
                <a href="/admin/dashboard"
                   class="inline-block bg-slate-900 text-white px-6 py-3 rounded-2xl font-black text-sm hover:bg-blue-600 transition-all">
                    Back to Dashboard
                </a>
            </div>
        <% } %>

    </div>

    <%- include('../partials/footer') %>
</body>
</html>
