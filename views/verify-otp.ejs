<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Access | BookVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .toast {
            visibility: hidden;
            min-width: 300px;
            color: #fff;
            text-align: center;
            border-radius: 16px;
            padding: 16px 24px;
            position: fixed;
            z-index: 1000;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.1);
            font-weight: 600;
        }
        .toast.show { visibility: visible; opacity: 1; bottom: 50px; }
        
        .otp-letter-spacing {
            letter-spacing: 0.75rem;
            text-indent: 0.75rem;
        }
    </style>
</head>
<body class="bg-[#f8fafc] font-sans antialiased text-slate-900">

<main class="min-h-screen flex items-center justify-center px-4 py-12">
    
    <div class="w-full max-w-md bg-white rounded-3xl p-8 md:p-10 shadow-2xl shadow-slate-200 border border-slate-100">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-50 rounded-2xl mb-4">
                <i class="fas fa-shield-check text-blue-600 text-2xl"></i>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Identity Check</h2>
            <p id="instructionText" class="text-slate-500 text-sm mt-3 leading-relaxed font-medium">
                Enter the 6-digit code sent to your email.
            </p>
        </div>

        <form id="verifyForm" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-1">Verification Code</label>
                <input type="text" id="otp" placeholder="000000" maxlength="6" required
                    class="otp-letter-spacing w-full py-4 bg-slate-50 border border-slate-100 rounded-2xl outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-50 transition-all text-center text-2xl font-black text-slate-900">
            </div>

            <button type="submit" id="verifyBtn"
                class="w-full bg-slate-900 text-white py-4 rounded-2xl font-bold text-lg shadow-xl shadow-slate-200 hover:bg-blue-600 active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Finalize Registration
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-slate-50">
            <div id="resend-section" class="text-sm font-medium text-slate-500">
                <p id="timerText" class="flex items-center justify-center gap-2">
                    <i class="fas fa-clock text-xs"></i> 
                    Resend available in <span id="timer" class="text-blue-600 font-bold">30</span>s
                </p>
                <button id="resendBtn" onclick="handleResend(event)" 
                    class="hidden text-blue-600 font-black hover:underline uppercase tracking-wider text-xs">
                    <i class="fas fa-redo-alt mr-1"></i> Request New Code
                </button>
            </div>

            <div class="mt-6">
                <a href="/signup" class="text-slate-400 hover:text-slate-900 transition-colors text-sm font-bold flex items-center justify-center gap-2">
                    <i class="fas fa-arrow-left text-xs"></i> Back to Signup
                </a>
            </div>
        </div>
    </div>
</main>

<div id="toast" class="toast"></div>

<script>
 // 1. IMPROVED STATE RECOVERY: Check both storage types for the email
    // During development, sometimes one gets cleared while the other persists.
    const email = sessionStorage.getItem("verifyEmail") || localStorage.getItem("verifyEmail");
    
    const toast = document.getElementById("toast");
    const verifyForm = document.getElementById("verifyForm");
    const verifyBtn = document.getElementById("verifyBtn");
    const otpInput = document.getElementById("otp");
    
    // Redirect if no email is found to prevent "undefined" errors
    if (!email) {
        window.location.href = "/signup";
    } else {
        document.getElementById("instructionText").innerHTML = `Code sent to: <span class="text-blue-600 font-bold">${email}</span>`;
    }

    // 2. INPUT SANITIZATION: Prevent non-numeric characters from being sent
    otpInput.addEventListener('input', (e) => {
        e.target.value = e.target.value.replace(/[^0-9]/g, '');
    });

    function showNotification(message, isError = true) {
        toast.innerText = message;
        toast.style.backgroundColor = isError ? "#ef4444" : "#2563eb";
        toast.classList.add("show");
        setTimeout(() => { toast.classList.remove("show"); }, 3500);
    }

    verifyForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const otp = otpInput.value;

        // Visual feedback
        verifyBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin"></i> Validating...`;
        verifyBtn.disabled = true;

        try {
            const res = await fetch("/verify-otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                // 3. EXPLICIT JSON: Ensure types are clear for the backend
                body: JSON.stringify({ 
                    email: email.trim(), 
                    otp: otp.toString() 
                })
            });

            const data = await res.json();

            // Check for success property specifically
            if (data.success || res.status === 200) {
                showNotification("Account Verified! Entering Vault...", false);
                
                // Cleanup
                sessionStorage.removeItem("verifyEmail");
                localStorage.removeItem("verifyEmail");

                setTimeout(() => { window.location.href = "/login"; }, 2000);
            } else {
                // Handle the "Verification sequence failed" error specifically
                showNotification(data.error || data.message || "Sequence failed. Check code.");
                verifyBtn.innerText = "Finalize Registration";
                verifyBtn.disabled = false;
            }
        } catch (err) {
            showNotification("Vault sync failed. Server unreachable.");
            verifyBtn.disabled = false;
            verifyBtn.innerText = "Finalize Registration";
        }
    });

    let timeLeft = 30;
    const timerSpan = document.getElementById("timer");
    const timerText = document.getElementById("timerText");
    const resendBtn = document.getElementById("resendBtn");

    function startTimer() {
        const countdown = setInterval(() => {
            timeLeft--;
            if(timerSpan) timerSpan.innerText = timeLeft;
            if (timeLeft <= 0) {
                clearInterval(countdown);
                timerText.classList.add("hidden");
                resendBtn.classList.remove("hidden");
            }
        }, 1000);
    }

    async function handleResend(e) {
        e.preventDefault();
        resendBtn.classList.add("hidden");
        timerText.classList.remove("hidden");
        timerText.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i>Sending...`;

        try {
            const res = await fetch("/resend-otp", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email })
            });
            
            if (res.ok) {
                showNotification("A new code has been issued.", false);
                timeLeft = 30;
                timerText.innerHTML = `<i class="fas fa-clock text-xs"></i> Resend available in <span id="timer" class="text-blue-600 font-bold">30</span>s`;
                startTimer();
            }
        } catch (err) {
            showNotification("Failed to transmit code.");
            resendBtn.classList.remove("hidden");
        }
    }

    startTimer();
</script>
</body>
</html>