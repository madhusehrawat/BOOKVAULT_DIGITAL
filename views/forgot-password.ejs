<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recover Access | BookVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --vault-navy: #1a2a6c;
            --vault-gold: #f1c40f;
            --vault-bg: #f4f7f6;
        }
        .toast {
            visibility: hidden; min-width: 300px; color: #fff; text-align: center;
            border-radius: 12px; padding: 16px 24px; position: fixed; z-index: 1000;
            left: 50%; bottom: 30px; transform: translateX(-50%); opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            font-weight: 600;
        }
        .toast.show { visibility: visible; opacity: 1; bottom: 50px; }
        .hidden-step { display: none; }
        
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="bg-[#f0f2f5] font-sans antialiased text-slate-800">

<%- include('partials/navbar', { user: locals.user || null }) %>

<main class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-12 bg-[url('https://www.transparenttextures.com/patterns/gray-paper.png')]">
    <div class="w-full max-w-md glass-card rounded-2xl p-8 md:p-10 shadow-2xl border border-slate-200">
        
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-50 rounded-full mb-4 border border-slate-100 shadow-sm">
                <i class="fas fa-book-reader text-[#1a2a6c] text-3xl"></i>
            </div>
            <h2 id="formTitle" class="text-3xl font-serif font-bold text-[#1a2a6c]">BookVault Recovery</h2>
            <p id="formDesc" class="text-slate-500 text-sm mt-3 leading-relaxed px-4">
                Enter your registered email and we'll send a secure access code to your inbox.
            </p>
        </div>

        <form id="step1Form" class="space-y-6">
            <div class="space-y-1">
                <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 ml-1">Library Email</label>
                <div class="relative group">
                    <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400 group-focus-within:text-[#1a2a6c]">
                        <i class="fas fa-envelope-open"></i>
                    </span>
                    <input type="email" id="email" placeholder="reader@bookvault.com" required
                        class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-[#1a2a6c] focus:ring-4 focus:ring-blue-50 transition-all">
                </div>
            </div>
            <button type="submit" id="sendOtpBtn"
                class="w-full bg-[#1a2a6c] text-white py-4 rounded-xl font-bold text-lg shadow-lg hover:bg-[#121d4a] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Send Recovery Code
                <i class="fas fa-quill-pen text-sm"></i>
            </button>
        </form>

        <form id="step2Form" class="space-y-6 hidden-step">
            <div class="space-y-4">
                <div class="space-y-1">
                    <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 ml-1">6-Digit Passkey</label>
                    <input type="text" id="otp" placeholder="000000" maxlength="6" required
                        class="w-full px-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-[#1a2a6c] text-center text-2xl tracking-[0.8em] font-mono font-bold text-[#1a2a6c]">
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 ml-1">New Vault Password</label>
                    <div class="relative">
                         <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-400">
                            <i class="fas fa-lock"></i>
                        </span>
                        <input type="password" id="newPassword" placeholder="••••••••" required
                            class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-[#1a2a6c]">
                    </div>
                </div>
            </div>
            <button type="submit" id="resetBtn"
                class="w-full bg-[#f1c40f] text-[#1a2a6c] py-4 rounded-xl font-bold text-lg shadow-lg hover:bg-[#d4ac0d] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Unlock Vault
                <i class="fas fa-key text-sm"></i>
            </button>
        </form>

        <div class="mt-8 text-center border-t border-slate-100 pt-6">
            <a href="/login" class="text-[#1a2a6c] font-bold hover:text-blue-800 flex items-center justify-center gap-2 text-xs uppercase tracking-widest transition-colors">
                <i class="fas fa-chevron-left text-[10px]"></i> Return to Archive
            </a>
        </div>
    </div>
</main>

<div id="toast" class="toast"></div>

<script>
    const step1Form = document.getElementById('step1Form');
    const step2Form = document.getElementById('step2Form');
    const formTitle = document.getElementById('formTitle');
    const formDesc = document.getElementById('formDesc');
    const toast = document.getElementById('toast');

    function showNotification(message, isError = true) {
        toast.innerText = message;
        toast.style.backgroundColor = isError ? "#b91c1c" : "#1e40af"; // Red for error, Blue for success
        toast.classList.add("show");
        setTimeout(() => { toast.classList.remove("show"); }, 3500);
    }


    step1Form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const btn = document.getElementById('sendOtpBtn');
        
        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-circle-notch fa-spin"></i> Checking Archive...`;

        try {
            const res = await fetch('/forgot-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });
            const data = await res.json();

            if (data.success) {
                showNotification("Recovery code sent to your email.", false);
                step1Form.classList.add('hidden-step');
                step2Form.classList.remove('hidden-step');
                formTitle.innerText = "Secure Entry";
                formDesc.innerText = `Verification code sent to ${email}.`;
            } else {
                showNotification(data.message || "Record not found.");
                btn.disabled = false;
                btn.innerHTML = `Send Recovery Code <i class="fas fa-quill-pen text-sm"></i>`;
            }
        } catch (err) {
            showNotification("Network error. Please try again.");
            btn.disabled = false;
        }
    });

    step2Form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const otp = document.getElementById('otp').value;
        const newPassword = document.getElementById('newPassword').value;
        const btn = document.getElementById('resetBtn');

        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-circle-notch fa-spin"></i> Updating Vault...`;

        try {
           
            const res = await fetch('/reset-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, otp, newPassword })
            });
            const data = await res.json();

            if (data.success) {
                showNotification("Vault updated! Entry granted.", false);
                setTimeout(() => { window.location.href = "/login"; }, 2000);
            } else {
                showNotification(data.message || "Invalid passkey.");
                btn.disabled = false;
                btn.innerHTML = `Unlock Vault <i class="fas fa-key text-sm"></i>`;
            }
        } catch (err) {
            showNotification("Network error.");
            btn.disabled = false;
        }
    });
</script>
</body>
</html>