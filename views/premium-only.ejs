<!DOCTYPE html>
<html>
<head>
    <title>Premium Access Only</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        function handlePremiumUpgrade() {
            alert('Redirecting to premium upgrade page...');
            // Here you would typically redirect to your pricing or upgrade page
            window.location.href = '/pricing';
        }   
    </script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    <div class="text-center p-10 bg-white rounded-3xl shadow-xl max-w-md">
        <div class="text-amber-500 mb-4">
            <i class="fas fa-crown text-5xl"></i>
        </div>
        <h1 class="text-2xl font-black text-gray-900 mb-2">Premium Content</h1>
        <p class="text-gray-500 mb-6">This asset is part of our Premium Vault. Please upgrade your account to unlock instant downloads.</p>
        
        <div class="flex flex-col gap-3">
            <button onclick="handlePremiumUpgrade()" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold">
                Upgrade to Premium
            </button>
            <a href="/books" class="text-blue-600 font-medium">Back to Library</a>
        </div>
    </div>
</body>
</html>