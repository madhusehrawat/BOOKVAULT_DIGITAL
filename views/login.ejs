<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | BookVault</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { 
            --vault-primary: #2563eb; 
            --vault-dark: #0f172a; 
        }
        
        /* Smooth Entrance */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in { animation: fadeInUp 0.6s ease-out forwards; }

        /* Error Shake Animation */
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-8px); }
            75% { transform: translateX(8px); }
        }
        .shake { animation: shake 0.4s ease-in-out; }
        
        .custom-ring:focus { 
            border-color: var(--vault-primary); 
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1); 
        }
    </style>
</head>
<body class="bg-[#f8fafc] font-sans antialiased text-slate-900 overflow-x-hidden">

    <div id="errorPopup" class="fixed bottom-8 left-1/2 -translate-x-1/2 z-[100] hidden flex items-center gap-4 bg-white border-l-4 border-red-500 px-6 py-4 rounded-2xl shadow-2xl transition-all duration-500 transform translate-y-32">
        <div class="bg-red-50 p-2 rounded-full text-red-500">
            <i class="fas fa-exclamation-circle text-lg"></i>
        </div>
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 leading-none mb-1">Access Denied</p>
            <p id="errorPopupMsg" class="text-sm font-bold text-slate-800">Invalid credentials</p>
        </div>
        <button onclick="hidePopup()" class="ml-4 text-slate-300 hover:text-slate-500">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <%- include('partials/navbar', { user: locals.user || null }) %>

    <main class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-12">
        
        <div id="loginCard" class="w-full max-w-md bg-white rounded-3xl p-8 md:p-10 shadow-2xl shadow-slate-200/50 border border-slate-100 animate-fade-in">
            
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-50 rounded-2xl mb-4">
                    <i class="fas fa-layer-group text-blue-600 text-2xl"></i>
                </div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">Welcome Back</h2>
                <p class="text-slate-500 text-sm mt-2 font-medium">Log in to access your digital library.</p>
            </div>

            <form id="loginForm" class="space-y-6">
                
                <div class="space-y-1">
                    <label for="email" class="text-[11px] font-black uppercase tracking-widest text-slate-400 ml-1">Vault ID / Email</label>
                    <div class="relative group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-300 group-focus-within:text-blue-600 transition-colors">
                            <i class="fas fa-envelope"></i>
                        </span>
                        <input type="email" id="email" placeholder="reader@bookvault.com" required
                            class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-100 rounded-2xl outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-50 transition-all font-medium">
                    </div>
                </div>

                <div class="space-y-1">
                    <div class="flex justify-between items-center px-1">
                        <label for="password" class="text-[11px] font-black uppercase tracking-widest text-slate-400">Password</label>
                        <a href="/forgot-password" class="text-[11px] font-bold text-blue-600 hover:text-blue-700 uppercase tracking-widest flex items-center gap-1 transition-colors">
                            <i class="fas fa-shield-alt text-[10px]"></i> Recover?
                        </a>
                    </div>
                    <div class="relative group">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-slate-300 group-focus-within:text-blue-600 transition-colors">
                            <i class="fas fa-lock"></i>
                        </span>
                        
                        <input type="password" id="password" placeholder="••••••••" required
                            class="w-full pl-11 pr-12 py-3.5 bg-slate-50 border border-slate-100 rounded-2xl outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-50 transition-all font-medium">
                        
                        <button type="button" id="togglePassword" class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-300 hover:text-slate-600 transition-colors">
                            <i class="fas fa-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" id="submitBtn"
                    class="w-full bg-slate-900 text-white py-4 rounded-2xl font-bold text-lg shadow-xl shadow-slate-200 hover:bg-blue-600 active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                    Unlock Vault
                    <i class="fas fa-arrow-right text-sm"></i>
                </button>
            </form>

            <div class="mt-8 text-center pt-6 border-t border-slate-50">
                <p class="text-slate-500 text-sm font-medium">
                    New to BookVault? 
                    <a href="/signup" class="text-blue-600 font-black hover:underline ml-1">Create Account</a>
                </p>
            </div>
        </div>
    </main>

    <script>
    
        const togglePassword = document.querySelector('#togglePassword');
        const passwordInput = document.querySelector('#password');
        const eyeIcon = document.querySelector('#eyeIcon');

        togglePassword.addEventListener('click', () => {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            eyeIcon.classList.toggle('fa-eye');
            eyeIcon.classList.toggle('fa-eye-slash');
        });


        let popupTimeout;
        function showPopup(message) {
            const popup = document.getElementById('errorPopup');
            const msgContainer = document.getElementById('errorPopupMsg');
            const card = document.getElementById('loginCard');

            msgContainer.textContent = message;
            popup.classList.remove('hidden');
            
            setTimeout(() => {
                popup.classList.remove('translate-y-32');
                popup.classList.add('translate-y-0');
            }, 10);

            card.classList.add('shake');
            setTimeout(() => card.classList.remove('shake'), 400);

            if (popupTimeout) clearTimeout(popupTimeout);
            popupTimeout = setTimeout(hidePopup, 5000);
        }

        function hidePopup() {
            const popup = document.getElementById('errorPopup');
            popup.classList.add('translate-y-32');
            popup.classList.remove('translate-y-0');
            setTimeout(() => popup.classList.add('hidden'), 500);
        }

    
        function urlBase64ToUint8Array(base64String) {
            const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
            const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);
            for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
        }

        const loginForm = document.getElementById('loginForm');
        const submitBtn = document.getElementById('submitBtn');

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

        
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<i class="fas fa-circle-notch fa-spin"></i> Authorizing...`;

            let subscription = null;

            try {
                if ('serviceWorker' in navigator && 'PushManager' in window) {
                    const registration = await navigator.serviceWorker.register('/sw.js');
                    const permission = await Notification.requestPermission();
                    if (permission === 'granted') {
                        const publicVapidKey = "<%= locals.publicVapidKey || '' %>";
                        if(publicVapidKey) {
                            subscription = await registration.pushManager.subscribe({
                                userVisibleOnly: true,
                                applicationServerKey: urlBase64ToUint8Array(publicVapidKey)
                            });
                        }
                    }
                }
            } catch (pushErr) {
                console.warn("Push subscription skipped:", pushErr);
            }

            const urlParams = new URLSearchParams(window.location.search);
            const returnTo = urlParams.get('returnTo') || '';

            try {
                const res = await fetch(`/login?returnTo=${encodeURIComponent(returnTo)}`, {
                    method: 'POST',
                    body: JSON.stringify({ email, password, subscription }), 
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await res.json();

                if (data.success) {
                
                    window.location.assign(data.redirectUrl || '/books'); 
                } else {
                    showPopup(data.error || "Login failed. Check your credentials.");
                    resetBtn();
                }
            } catch (err) {
                showPopup("Connection to Vault failed. Try again.");
                resetBtn();
            }
        });

        function resetBtn() {
            submitBtn.disabled = false;
            submitBtn.innerHTML = `Unlock Vault <i class="fas fa-arrow-right text-sm"></i>`;
        }
    </script>
</body>
</html>